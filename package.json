    "storybook": "EXPO_PUBLIC_STORYBOOK=true expo start",
    "storybook:generate": "sb-rn-get-stories --config-path .storybook",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
